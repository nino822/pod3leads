# Google OAuth2 Credentials
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Sheet ID
# From: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Service Account (Optional - for server-side fallback)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase (used for OTP email sending - free, no domain required)
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NextAuth Secret
NEXTAUTH_SECRET=your_random_secret_here_generate_with_openssl_rand_base64_32

# NextAuth URL
NEXTAUTH_URL=http://localhost:3000

# Comma-separated admin emails (case-insensitive). Only admins can invite users.
ADMIN_EMAILS=owner@example.com

# Database URLs (PostgreSQL)
# Use pooled URL for app/runtime traffic (PgBouncer/session pooler)
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# Use direct URL for Prisma migrations/introspection
DIRECT_URL="postgresql://USER:PASSWORD@DB_HOST:5432/postgres?sslmode=require"

# Preferred email provider (Resend)
RESEND_API_KEY=re_your_resend_api_key
# Optional. Defaults to onboarding@resend.dev for quick start.
RESEND_FROM_EMAIL=onboarding@yourdomain.com

# Gmail SMTP fallback for invite and auth emails
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional sender identity shown in recipient inbox
EMAIL_FROM_NAME=Pod 3 Dashboard
EMAIL_FROM_EMAIL=your-email@gmail.com